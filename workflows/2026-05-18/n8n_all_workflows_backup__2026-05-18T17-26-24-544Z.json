            "jsCode": "const cfg = $node[\"CFG - Backup Config\"].json;\nconst items = $input.all();\n\nconst now = new Date();\nconst date = now.toISOString().slice(0, 10);\nconst timestamp = now.toISOString().replace(/[:.]/g, \"-\");\n\nconst workflows = items.map((item, index) => {\n  const workflow = item.json.data || item.json;\n\n  if (!workflow.id || !workflow.name) {\n    throw new Error(\n      `Workflow item ${index + 1} is missing id or name. Check that this node is connected after \"N8N - Get Workflow\".`\n    );\n  }\n\n  return workflow;\n});\n\nconst backupPayload = {\n  exported_at: now.toISOString(),\n  source: \"n8n-public-api\",\n  project: \"Ocean Sentinel / PILAT\",\n  backup_type: \"all_workflows_bundle\",\n  workflow_count: workflows.length,\n  warning: \"Workflow JSON backup. Credentials secrets are not stored here.\",\n  workflows\n};\n\nconst jsonText = JSON.stringify(backupPayload, null, 2);\nconst contentBase64 = Buffer.from(jsonText, \"utf8\").toString(\"base64\");\n\nreturn [\n  {\n    json: {\n      repo_owner: cfg.repo_owner,\n      repo_name: cfg.repo_name,\n      branch: cfg.branch,\n      exported_at: now.toISOString(),\n      workflow_count: workflows.length,\n      path: `${cfg.backup_root}/${date}/n8n_all_workflows_backup__${timestamp}.json`,\n      content_b64: contentBase64,\n      commit_message: `backup(n8n): all workflows bundle - ${workflows.length} workflows - ${now.toISOString()}`\n    }\n  }\n];"
