          ],
          "id": "51749447-eb3e-4d2e-a0b6-4d8c7ea6cb2a",
          "name": "CODE - Strict Validation Filter"
        },
        {
          "parameters": {
            "jsCode": "const EXPECTED_COUNT = 30;\nconst REQUIRED_COLLECTION = 'pilat_validated_doctrine_v1';\n\nconst items = $input.all();\n\nconst summary = {\n  total_items: items.length,\n  validated: 0,\n  human_validated: 0,\n  index_ready: 0,\n  wrong_collection: 0,\n  invalid_items: []\n};\n\nfor (const [index, item] of items.entries()) {\n  const j = item.json;\n\n  const isValidated = j.statut_document === 'VALIDATED';\n  const isHumanValidated = j.validation === 'validé_humainement';\n  const isIndexReady = j.index_ready === true;\n  const isRightCollection = j.collection_name === REQUIRED_COLLECTION;\n\n  if (isValidated) summary.validated++;\n  if (isHumanValidated) summary.human_validated++;\n  if (isIndexReady) summary.index_ready++;\n  if (!isRightCollection) summary.wrong_collection++;\n\n  if (!isValidated || !isHumanValidated || !isIndexReady || !isRightCollection) {\n    summary.invalid_items.push({\n      index,\n      chunk_id: j.chunk_id,\n      statut_document: j.statut_document,\n      validation: j.validation,\n      index_ready: j.index_ready,\n      collection_name: j.collection_name\n    });\n  }\n}\n\nif (summary.total_items !== EXPECTED_COUNT) {\n  throw new Error(`HOLD: expected ${EXPECTED_COUNT} chunks, got ${summary.total_items}`);\n}\n\nif (summary.invalid_items.length > 0) {\n  throw new Error(\n    `HOLD: invalid chunks detected: ${JSON.stringify(summary.invalid_items.slice(0, 10))}`\n  );\n}\n\n// Important : on certifie, puis on laisse passer les 30 chunks\nreturn items.map(item => ({\n  json: {\n    ...item.json,\n    qa_decision: 'GO',\n    qa_message: 'QA passed — chunk validated for vector ingestion.',\n    qa_expected_count: EXPECTED_COUNT,\n    qa_total_items: summary.total_items,\n    qa_validated: summary.validated,\n    qa_human_validated: summary.human_validated,\n    qa_index_ready: summary.index_ready\n  }\n}));"
          },
