          "id": "3b1f6e65-d892-46ec-bf9f-f6ad13ee0477",
          "name": "EXTRACT - JSONL Text"
        },
        {
          "parameters": {
            "jsCode": "const EXPECTED_COUNT = 30;\n\nfunction getExtractedText(item) {\n  return (\n    item.json.jsonl_raw ||\n    item.json.data ||\n    item.json.text ||\n    item.json.content ||\n    ''\n  );\n}\n\nconst accepted = [];\nconst rejected = [];\n\nfor (const item of $input.all()) {\n  const raw = getExtractedText(item);\n\n  const lines = String(raw)\n    .split(/\\r?\\n/)\n    .map(line => line.trim())\n    .filter(Boolean);\n\n  for (const [lineIndex, line] of lines.entries()) {\n    let obj;\n\n    try {\n      obj = JSON.parse(line);\n    } catch (error) {\n      rejected.push({\n        line: lineIndex + 1,\n        reason: 'invalid_json',\n        preview: line.slice(0, 200)\n      });\n      continue;\n    }\n\n    const statut =\n      obj.statut ||\n      obj.statut_document ||\n      obj.metadata?.statut ||\n      obj.metadata?.statut_document;\n\n    const validation =\n      obj.validation ||\n      obj.metadata?.validation;\n\n    const content =\n      obj.contenu_chunk ||\n      obj.content ||\n      obj.text ||\n      obj.pageContent ||\n      '';\n\n    const chunkId =\n      obj.chunk_id ||\n      obj.metadata?.chunk_id ||\n      `pilat_chunk_${String(lineIndex + 1).padStart(4, '0')}`;\n\n    const forbiddenStatuses = new Set([\n      'REVIEW',\n      'DRAFT',\n      'DEPRECATED',\n      'ARCHIVED'\n    ]);\n\n    if (forbiddenStatuses.has(statut)) {\n      rejected.push({\n        chunk_id: chunkId,\n        statut,\n        validation,\n        reason: `forbidden_status_${statut}`\n      });\n      continue;\n    }\n\n    if (statut !== 'VALIDATED') {\n      rejected.push({\n        chunk_id: chunkId,\n        statut,\n        validation,\n        reason: 'not_validated'\n      });\n      continue;\n    }\n\n    if (!content || content.length < 10) {\n      rejected.push({\n        chunk_id: chunkId,\n        statut,\n        validation,\n        reason: 'empty_or_too_short_content'\n      });\n      continue;\n    }\n\n    accepted.push({\n      json: {\n        chunk_id: chunkId,\n        document_id: obj.document_id || 'pilat_doctrine',\n        source_file: obj.source_file || 'pilat_production_candidate_chunks.jsonl',\n        document_title: obj.document_title || '',\n        section_path: obj.section_path || '',\n        version: obj.version || '1.0.0',\n        statut_document: statut,\n        validation: validation || 'validé_humainement',\n        data_status: obj.data_status || 'DOCTRINE',\n        territoire: obj.territoire || 'non_specifie',\n        date_reference: obj.date_reference || '',\n        confidence_level: obj.confidence_level || 'élevé',\n        tags: obj.tags || ['pilat', 'validated', 'doctrine'],\n        word_count: obj.word_count || null,\n        content,\n        collection_name: 'pilat_validated_doctrine_v1',\n        ingestion_rule: 'validated_human_only',\n        index_ready: true\n      }\n    });\n  }\n}\n\nif (accepted.length !== EXPECTED_COUNT) {\n  throw new Error(\n    `HOLD: expected ${EXPECTED_COUNT} validated chunks, got ${accepted.length}. Rejected: ${rejected.length}. Details: ${JSON.stringify(rejected.slice(0, 10))}`\n  );\n}\n\nreturn accepted;"
          },
