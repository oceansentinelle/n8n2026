          "jsCode": "const lookup = $json || {};\nconst source = $('LOOP - One Workflow at a Time').item.json;\n\nconst sha =\n  lookup.sha ||\n  lookup.body?.sha ||\n  lookup.content?.sha ||\n  null;\n\nreturn {\n  json: {\n    repo_owner: source.repo_owner,\n    repo_name: source.repo_name,\n    branch: source.branch,\n    path: source.path,\n    message: source.commit_message,\n    content: source.content_b64,\n    github_exists: Boolean(sha),\n    sha\n  }\n};"
