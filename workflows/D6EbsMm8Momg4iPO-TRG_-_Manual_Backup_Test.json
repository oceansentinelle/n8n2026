        "credentials": {
          "httpHeaderAuth": {
            "id": "lmpA7bvhUojvSRyb",
            "name": "Header Auth account"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const cfg = $node[\"CFG - Backup Config\"].json;\nconst items = $input.all();\n\nconst now = new Date();\n\nfunction slugify(value) {\n  return String(value || \"unnamed-workflow\")\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .replace(/[^a-zA-Z0-9-_]+/g, \"_\")\n    .replace(/^_+|_+$/g, \"\")\n    .slice(0, 120);\n}\n\nreturn items.map((item, index) => {\n  const workflow = item.json.data || item.json;\n\n  if (!workflow.id || !workflow.name) {\n    throw new Error(\n      `Workflow item ${index + 1} is missing id or name. Check that this node is connected after \"N8N - Get Workflow\".`\n    );\n  }\n\n  const workflowId = workflow.id;\n  const workflowName = workflow.name;\n  const safeName = slugify(workflowName);\n\n  const backupPayload = {\n    exported_at: now.toISOString(),\n    source: \"n8n-public-api\",\n    backup_type: \"stable_single_workflow_file\",\n    workflow_id: workflowId,\n    workflow_name: workflowName,\n    warning: \"Workflow JSON backup. Credentials secrets are not stored here.\",\n    workflow\n  };\n\n  const jsonText = JSON.stringify(backupPayload, null, 2);\n  const contentBase64 = Buffer.from(jsonText, \"utf8\").toString(\"base64\");\n\n  return {\n    json: {\n      repo_owner: cfg.repo_owner,\n      repo_name: cfg.repo_name,\n      branch: cfg.branch,\n      workflow_id: workflowId,\n      workflow_name: workflowName,\n      path: `${cfg.backup_root}/${workflowId}-${safeName}.json`,\n      content_b64: contentBase64,\n      commit_message: `backup(n8n): update ${workflowName} - ${now.toISOString()}`\n    }\n  };\n});"
        },
