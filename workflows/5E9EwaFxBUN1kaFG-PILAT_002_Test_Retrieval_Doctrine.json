      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\nconst retrievedDocuments = items.map((item, index) => {\n  const document = item.json.document || {};\n  const metadata = document.metadata || {};\n  const pageContent = document.pageContent || \"\";\n  const score = item.json.score ?? null;\n\n  return {\n    rank: index + 1,\n    score,\n    chunk_id: metadata.chunk_id || null,\n    document_title: metadata.document_title || null,\n    section_path: metadata.section_path || null,\n    statut_document: metadata.statut_document || null,\n    validation: metadata.validation || null,\n    content: pageContent\n  };\n});\n\nreturn [\n  {\n    json: {\n      question: \"Pourquoi SCENARIO != MEASURED ?\",\n      retrieved_count: retrievedDocuments.length,\n      retrieved_documents: JSON.stringify(retrievedDocuments, null, 2),\n      decision_retrieval: retrievedDocuments.length > 0 ? \"GO\" : \"HOLD\"\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
